rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    // Requester's Firestore profile (1 read, cached per request)
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasClaimRole(role) {
      return 'role' in request.auth.token && request.auth.token.role == role;
    }

    // Roles can live in custom claims (set via the setCustomClaims function)
    // or in the user profile document; accept either so legacy users work.
    function isAdmin() {
      return isSignedIn()
        && (hasClaimRole('admin')
            || ('admin' in request.auth.token && request.auth.token.admin == true)
            || userData().role == 'admin');
    }

    function isManagerOrAdmin() {
      return isSignedIn()
        && (hasClaimRole('admin')
            || hasClaimRole('manager')
            || ('admin' in request.auth.token && request.auth.token.admin == true)
            || userData().role in ['manager', 'admin']);
    }

    function isManagerOfCompany(companyId) {
      return isManagerOrAdmin() && userData().company == companyId && companyId != '';
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Self-service company assignment is only valid when the company's email
    // domain matches the authenticated email (or when clearing the field).
    function canSelfAssignCompany(companyId) {
      return companyId == ''
        || get(/databases/$(database)/documents/companies/$(companyId)).data.emailDomain
             == request.auth.token.email.split('@')[1];
    }

    // ---------- users ----------

    match /users/{userId} {
      // Own profile, managers of the same company, or admins
      allow read: if isSignedIn()
        && (request.auth.uid == userId
            || isAdmin()
            || isManagerOfCompany(resource.data.company));

      // Self-registration: must match the authenticated user, start as 'user',
      // and only join a company whose domain matches the email
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'user'
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && canSelfAssignCompany(request.resource.data.company);

      // Owners may update their profile but never their own role, and may only
      // self-assign a company matching their email domain.
      // Managers may manage locCode / company membership / role-downgrade for their company.
      // Admins may update anything.
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && !('role' in changedKeys())
            && (!('company' in changedKeys())
                || canSelfAssignCompany(request.resource.data.company)))
        || (isManagerOfCompany(resource.data.company)
            && changedKeys().hasOnly(['locCode', 'company', 'role', 'updatedAt'])
            && (!('role' in changedKeys()) || request.resource.data.role == 'user'));

      allow delete: if isAdmin();
    }

    // ---------- companies ----------

    match /companies/{companyId} {
      // Needed for logo display and email-domain matching at registration
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- products ----------

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Managers may only maintain buyer costs (CSV import)
      allow update: if isAdmin()
        || (isManagerOrAdmin() && changedKeys().hasOnly(['buyerCost', 'updatedAt']));
    }

    // ---------- carts ----------

    match /carts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /items/{itemId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ---------- orders ----------

    match /orders/{orderId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || isAdmin()
            || isManagerOfCompany(resource.data.companyId));

      // Users place their own pending orders for their own company
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.companyId == userData().company
        && request.resource.data.companyId != ''
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 500;

      // Owners may only cancel their own pending orders;
      // managers/admins manage the status lifecycle and tracking info
      allow update: if isAdmin()
        || (isManagerOfCompany(resource.data.companyId)
            && changedKeys().hasOnly(['status', 'trackingInfo', 'updatedAt']))
        || (resource.data.userId == request.auth.uid
            && resource.data.status == 'pending'
            && changedKeys().hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'cancelled');

      allow delete: if isAdmin() || isManagerOfCompany(resource.data.companyId);
    }

    // Everything else (incl. legacy campaigns collection) is admin-only
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
